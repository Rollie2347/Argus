# ============================================================
# Argus v0.3 — Environment Variables
# ============================================================

# REQUIRED — Google AI Studio API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# REQUIRED — Google Cloud project ID (for Firestore memory)
GCP_PROJECT_ID=your_gcp_project_id

# Server port (Cloud Run sets this automatically)
PORT=8080

# ============================================================
# OPTIONAL — Customize location for weather + restaurant lookup
# Defaults to Chicago if not set
# ============================================================
WEATHER_LAT=41.88
WEATHER_LON=-87.63

# Your timezone (for time-aware responses)
# List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Chicago

# ============================================================
# LOCAL DEVELOPMENT ONLY
# ============================================================
# Path to your GCP service account key JSON (for local Firestore access)
# On Cloud Run, default credentials are used automatically (no file needed)
# To create: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download JSON key and save as backend/service-account.json
# (service-account.json is gitignored — never commit it)
